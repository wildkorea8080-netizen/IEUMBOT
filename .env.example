# -----------------------------------------------------------------------------
# Global
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=ieumbot
POSTGRES_USER=ieumbot
POSTGRES_PASSWORD=ieumbot
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_PORT=8000
API_DATABASE_URL=postgresql+psycopg://ieumbot:ieumbot@postgres:5432/ieumbot
# Redis: Arq 워커(USE_ARQ_WORKER=true) + 공유 캐시(embedding 7d, 기타) 백엔드.
# 비워두거나 unreachable이면 Arq 비활성 + 캐시는 in-memory fallback.
API_REDIS_URL=redis://redis:6379/0
API_OPENAI_API_KEY=
API_SESSION_SECRET=change-me
API_ACCESS_TOKEN_EXPIRE_MINUTES=720
API_FILE_STORAGE_DRIVER=local
API_FILE_STORAGE_BUCKET=ieumbot-docs
API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Arq 워커로 재색인/크롤 디스패치. true 시 워커 컨테이너(infra/docker/worker.Dockerfile) 필수.
# false면 FastAPI BackgroundTasks(동일 프로세스) — 단일 인스턴스 배포만 안전.
# 다중 인스턴스/Coolify 배포 시 반드시 true + API_REDIS_URL 가용 보장.
USE_ARQ_WORKER=false

# -----------------------------------------------------------------------------
# Web (Next.js)
# -----------------------------------------------------------------------------
WEB_PORT=3000
WEB_PUBLIC_API_BASE_URL=http://localhost:8000/api

# -----------------------------------------------------------------------------
# Widget
# -----------------------------------------------------------------------------
WIDGET_PUBLIC_API_BASE_URL=http://localhost:8000/api
WIDGET_PUBLIC_ASSET_BASE_URL=http://localhost:8080
