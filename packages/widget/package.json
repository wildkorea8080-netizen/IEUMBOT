{
  "name": "@ieumbot/widget",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "echo \"Use `pnpm --filter @ieumbot/widget build --watch` for local widget bundling.\"",
    "build": "pnpm exec esbuild src/index.ts --bundle --format=iife --platform=browser --target=es2020 --outfile=../../apps/web/public/widget.js --minify",
    "lint": "pnpm exec eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "pnpm exec tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "esbuild": "0.25.4"
  }
}
